HA_URL=http://192.168.1.x:30103
HA_URL_EXTERNAL=https://home-assistant.example.com
HA_TOKEN=your_long_lived_access_token_here
SERVER_PORT=3001
VITE_API_URL=http://localhost:3001

# Auth — generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
AUTH_PASSWORD_HASH=$2b$12$...

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_random_64_char_secret_here
